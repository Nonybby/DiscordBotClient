{
  "name": "discord-bot-client",
  "productName": "DiscordBotClient",
  "version": "3.8.2",
  "description": "DiscordBotClient - login into discord with a bot token",
  "author": {
    "name": "aiko-chan-ai",
    "email": "Aiko@shiroko.onmicrosoft.com"
  },
  "repository": {
    "url": "https://github.com/aiko-chan-ai/DiscordBotClient/"
  },
  "license": "GPL-3.0",
  "main": "build/index.js",
  "scripts": {
    "test": "npm run build:ts && npm run start",
    "test:typescript": "tsc --noEmit",
    "build:ts": "tsc && tsc-alias",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "vencord": "tsx scripts/vencordBuild.ts",
    "core:update": "tsx scripts/update.ts",
    "start": "electron .",
    "mac": "electron-builder -m",
    "win": "electron-builder -w",
    "linux": "electron-builder -l",
    "build": "electron-builder",
    "requirement": "npm install && tsx scripts/vencordClone.ts",
    "cerf": "openssl req -nodes -new -x509 -keyout ./assets/cert/server.key -out ./assets/cert/server.cert -days 3650 -subj \"/CN=localhost\""
  },
  "keywords": [],
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^4.17.23",
    "@types/http-proxy": "^1.17.17",
    "@types/ini": "^4.1.1",
    "@types/js-beautify": "^1.14.3",
    "@types/jsdom": "^27.0.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.0",
    "@types/probe-image-size": "^7.2.5",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-header": "^1.2.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "js-beautify": "^1.15.4",
    "jsdom": "^27.3.0",
    "pnpm": "^10.25.0",
    "prettier": "^3.7.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0"
  },
  "dependencies": {
    "@sapphire/snowflake": "^3.5.5",
    "dexie": "^4.2.1",
    "discord-api-types": "^0.38.36",
    "discord-protos": "^1.2.89",
    "electron-context-menu": "^4.1.1",
    "electron-log": "^5.4.3",
    "express": "^4.21.2",
    "ini": "^6.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "murmurhash": "^2.0.1",
    "probe-image-size": "^7.2.3",
    "undici": "^7.16.0"
  },
  "build": {
    "files": [
      "!docs",
      "!scripts",
      "!Vencord",
      "!src",
      "!tsconfig.json",
      "!tsup.config.ts",
      "!.eslintrc.json",
      "!.gitattributes",
      "!.gitignore",
      "!.prettierrc.json",
      "!eslint.config.mjs",
      "!readme.md",
      "assets",
      "build",
      "VencordExtension"
    ],
    "appId": "DiscordBotClient",
    "productName": "DiscordBotClient",
    "artifactName": "${productName}-${os}-${arch}.${ext}",
    "copyright": "Copyright © 2025 aiko-chan-ai",
    "mac": {
      "category": "public.app-category.social-networking",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true,
      "icon": "./assets/icon.png",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "This app needs access to the microphone",
        "com.apple.security.device.audio-input": true
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "desktop": {
        "entry": {
          "Name": "DiscordBotClient",
          "GenericName": "Internet Messenger",
          "Type": "Application",
          "Categories": "Network;InstantMessaging;Chat;",
          "Keywords": "discord;bot;vencord;electron;chat;"
        }
      },
      "category": "Network",
      "icon": "./assets/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "./assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "./LICENSE"
    },
    "asar": false
  }
}
